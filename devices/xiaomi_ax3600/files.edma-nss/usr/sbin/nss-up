#!/bin/sh
# Bring up the FULL NSS stack (M5): fw data plane + ath11k Wi-Fi offload +
# ECM offload + PPPoE connmgr + SQM. Run after boot; reboot to undo.
#
# M5 boot model: ath11k carries symbol deps on qca-nss-drv, so kmodloader
# loads drv at boot, but its probe is DEFERRED by the qca-ppe-nss gate.
# Writing fw_mask boots the firmware synchronously (the glue re-attaches
# the deferred core devices inside the write).
set -e
FWM=/sys/kernel/debug/qca-ppe-nss/fw_mask
modprobe qca-ppe-nss 2>/dev/null || true
[ "$(cat $FWM 2>/dev/null)" = "0x0" ] || { echo "already armed or glue missing - reboot first"; exit 1; }
modprobe qca-nss-drv 2>/dev/null || true

echo 0x3c > $FWM
[ "$(cat $FWM)" = "0x3c" ] || { echo "arming failed, fw not booted"; exit 1; }
sleep 8
grep -E "if_num [2-5]:" /sys/kernel/debug/qca-ppe-nss/status

# The firmware data plane is armed (the critical section above is guarded with
# explicit '|| { ...; exit 1; }'). Everything from here on - bridge-mgr, qca-mcs,
# ECM, pppoe, the Wi-Fi flip, WAN, SQM - is OPT-IN and best-effort: a failure
# must NOT abort the script and leave the fw armed without ECM. In particular ECM
# hard-depends on qca-mcs (ECM_MULTICAST_ENABLE), so 'modprobe ecm' can fail if
# qca-mcs is missing/broken - don't let that take down the rest of the plane.
set +e

# bridge-mgr: offload Linux-bridge L2 forwarding into the firmware. Load after
# the fw data plane is up (ports armed) and before ECM, so the firmware bridge
# interface exists when ECM classifies bridged flows. On load it walks the
# existing bridge's members and joins the qca_ppe (wired) ports; Wi-Fi members
# are skipped until they are NSS interfaces.
modprobe qca-nss-bridge-mgr 2>/dev/null || true

# qca-mcs: IGMP/MLD bridge snooping + the membership source the ECM multicast
# classifier reads. Load before ECM so the classifier binds qca-mcs's hooks;
# this is what lets snooped multicast groups be replicated in PPE hardware
# instead of host-flooded to every bridge port.
modprobe qca-mcs 2>/dev/null || true

sysctl -w net.netfilter.nf_conntrack_events=1
sysctl -w net.netfilter.nf_conntrack_tcp_no_window_check=1
modprobe ecm front_end_selection=1
sleep 2
echo 1 > /sys/kernel/debug/ecm/ecm_classifier_default/accel_delay_pkts
modprobe qca-nss-pppoe

# M5: Wi-Fi offload. Flip nss_offload and rebind the radio so ath11k
# re-registers against the NSS data path (wifili); pbuf re-applies the
# 512MB n2h pool tuning and runs `wifi up`. If the radios fail to
# register, fall back to host-mode Wi-Fi (the recovery/escape path).
if [ -w /sys/module/ath11k/parameters/nss_offload ]; then
  wifi down   # tear down hostapd ifaces first (pending-ack WARN at unbind otherwise)
  sleep 3
  echo 1 > /sys/module/ath11k/parameters/nss_offload
  echo c000000.wifi > /sys/bus/platform/drivers/ath11k/unbind
  sleep 3
  echo c000000.wifi > /sys/bus/platform/drivers/ath11k/bind
  sleep 12
  if [ "$(ls /sys/class/ieee80211/ 2>/dev/null | wc -l)" -lt 2 ]; then
    echo "WIFI OFFLOAD FAILED - falling back to host-mode wifi"
    echo 0 > /sys/module/ath11k/parameters/nss_offload
    echo c000000.wifi > /sys/bus/platform/drivers/ath11k/unbind 2>/dev/null
    sleep 3
    echo c000000.wifi > /sys/bus/platform/drivers/ath11k/bind
    sleep 10
  fi
  /etc/init.d/qca-nss-pbuf start
fi

# WAN + SQM bring-up is best-effort with retries (set +e is already in effect
# from just after the firmware-arm critical section above).

ifup wan

# Wait for the PPPoE WAN to obtain an L3 address before starting SQM.
# nss-edma.qos's check_addr aborts ("no IP on wan (proto=pppoe)") when
# pppoe-wan has no address yet, and the iface hotplug for an interface='wan'
# SQM section does not reliably re-fire -> with only a fixed sleep, PPPoE
# negotiation outlasts the wait at boot and SQM silently never starts.
# Poll pppoe-wan for up to ~60s instead.
i=0
while [ $i -lt 30 ]; do
  if ip -4 addr show dev pppoe-wan 2>/dev/null | grep -q "inet " \
     || ip -6 addr show dev pppoe-wan scope global 2>/dev/null | grep -q "inet6 "; then
    break
  fi
  i=$((i + 1))
  sleep 2
done
if [ $i -lt 30 ]; then
  echo "pppoe-wan has an IP after ~$((i * 2))s"
else
  echo "WARN: pppoe-wan still has no IP after 60s; starting SQM anyway"
fi

# let the link settle, then flush conntrack/ECM so flows re-accelerate cleanly
sleep 3
echo 1 > /sys/kernel/debug/ecm/ecm_db/defunct_all 2>/dev/null
echo f > /proc/net/nf_conntrack 2>/dev/null
echo "NSS+wifi+ECM up. accel counts:"
cat /sys/kernel/debug/ecm/ecm_nss_ipv4/accelerated_count /sys/kernel/debug/ecm/ecm_nss_ipv6/accelerated_count

# Routed (L3) multicast: start the IGMP proxy now that pppoe-wan has an address.
# Opt-in with this script; its init is disabled at boot (uci-defaults 997) so it
# never runs on a host-only boot. start_service self-guards (returns early unless
# a configured upstream phyint is up), so this is safe to call unconditionally and
# is a no-op without a WAN multicast source. Each kernel MFC entry igmpproxy
# installs becomes a PPE hardware rule via ECM's routed-mc classifier (watch
# ipv4_mc_connection_create_requests in /sys/kernel/debug/qca-nss-drv/stats/ipv4).
[ -x /usr/sbin/igmpproxy ] && /etc/init.d/igmpproxy start 2>/dev/null || true

# Start SQM, retrying until the NSS shaper actually attaches to wan
# (check_addr can still lose a race in the first moments after the IP appears).
if /etc/init.d/sqm enabled; then
  j=0
  while [ $j -lt 5 ]; do
    j=$((j + 1))
    /etc/init.d/sqm restart >/dev/null 2>&1
    sleep 3
    if tc qdisc show dev wan 2>/dev/null | grep -q nsstbl; then
      echo "SQM active on wan (attempt $j)"
      break
    fi
    echo "SQM not attached yet, retry $j/5"
    sleep 3
  done
  if ! tc qdisc show dev wan 2>/dev/null | grep -q nsstbl; then
    echo "WARN: SQM still not attached after 5 attempts"
  fi
fi
